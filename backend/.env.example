PORT=3000

# Use either the split DB_* fields below or a single URL:
# - POSTGRES_SSL_URL=postgres://...?...sslmode=require
# - DATABASE_URL=postgres://...?...sslmode=require
# - POSTGRES_URL=postgres://...?...sslmode=require
# Optional SSL overrides:
# - DB_SSL=true
# - DB_SSL_REJECT_UNAUTHORIZED=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory
DB_USER=postgres
DB_PASSWORD=password
APP_UUID_SALT=82d16973-bfce-44f6-a032-22420c3cf964
JWT_SECRET=a03aba13fcef1029fe9b71db26cd0a1b7dfcb1fba1506d7f60ee22015223902e
BCRYPT_ROUNDS=10
AUTH_BACKEND_API=replace-with-base64-backend-api-key
AUTH_ENABLE_BACKEND_API_BYPASS=false

# AWS / Cognito
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_B4ufRbTLb
COGNITO_CLIENT_ID=k89j54t45niq4rvc61cjng76u

# S3 image uploads
# Used for both:
# - images/products/<orgId>/...
# - images/profiles/<accountId>/...
S3_PRODUCT_IMAGE_BUCKET=replace-with-s3-bucket-name
S3_PRODUCT_IMAGE_PUBLIC_BASE_URL=

# Demo provisioning
DEMO_DEFAULT_ORG_ENABLED=false
DEMO_DEFAULT_ORG_NAME=Developer Workspace
DEMO_DEFAULT_ROLE_NAME=Developer

# Frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
